pipeline {

    agent any

    options {
        timestamps()
        ansiColor('xterm')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 60, unit: 'MINUTES')
    }

    tools {
        jdk 'JDK21'
        maven 'Maven3'
    }

    environment {

        APP_NAME = "boardgame"

        AWS_REGION = "ap-south-1"

        AWS_ACCOUNT = "123456789012"

        ECR_REPOSITORY = "boardgame"

        IMAGE_TAG = "${BUILD_NUMBER}-${GIT_COMMIT.take(8)}"

        SCANNER_HOME = tool('SonarScanner')
    }

    stages {

        stage('Checkout') {

            steps {

                checkout scm

            }

        }

        stage('Compile') {

            steps {

                sh 'mvn clean compile'

            }

        }

        stage('Unit Test') {

            steps {

                sh 'mvn test'

            }

            post {

                always {

                    junit '**/target/surefire-reports/*.xml'

                }

            }

        }

        stage('Security Scans') {

            parallel {

                stage('Gitleaks Scan') {

                    steps {

                        sh '''

                        gitleaks detect \
                        --source . \
                        --verbose

                        '''

                    }

                }

                stage('Trivy Filesystem Scan') {

                    steps {

                        sh '''

                        trivy fs \
                        --severity HIGH,CRITICAL \
                        --exit-code 0 \
                        .

                        '''

                    }

                }

                stage('Checkov Scan') {

                    steps {

                        sh '''

                        checkov \
                        -d .

                        '''

                    }

                }

            }

        }

        stage('SonarQube Analysis') {

            steps {

                withSonarQubeEnv('sonar') {

                    sh """

                    ${SCANNER_HOME}/bin/sonar-scanner \
                    -Dsonar.projectKey=${APP_NAME} \
                    -Dsonar.projectName=${APP_NAME}

                    """

                }

            }

        }

        stage('Quality Gate') {

            steps {

                timeout(time: 10, unit: 'MINUTES') {

                    waitForQualityGate abortPipeline: true

                }

            }

        }

        stage('Package') {

            steps {

                sh 'mvn clean package -DskipTests'

            }

        }

        stage('Publish Artifact To Nexus') {

            steps {

                withMaven(

                    jdk: 'JDK21',

                    maven: 'Maven3',

                    globalMavenSettingsConfig: 'global-settings'

                ) {

                    sh 'mvn deploy'

                }

            }

        }

        stage('Build Docker Image') {

            steps {

                sh """

                docker build \
                -t ${AWS_ACCOUNT}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPOSITORY}:${IMAGE_TAG} \
                .

                """

            }

        }

                stage('Image Security') {

            parallel {

                stage('Trivy Image Scan') {

                    steps {

                        sh """

                        trivy image \
                        --severity HIGH,CRITICAL \
                        --exit-code 0 \
                        ${AWS_ACCOUNT}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPOSITORY}:${IMAGE_TAG}

                        """

                    }

                }

                stage('Generate SBOM') {

                    steps {

                        sh """

                        trivy image \
                        --format cyclonedx \
                        --output sbom.json \
                        ${AWS_ACCOUNT}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPOSITORY}:${IMAGE_TAG}

                        """

                    }

                }

            }

        }

        stage('Authenticate AWS') {

            steps {

                withAWS(

                    credentials: 'aws-dev',

                    region: "${AWS_REGION}"

                ) {

                    sh '''

                    aws sts get-caller-identity

                    '''

                }

            }

        }

        stage('Login To Amazon ECR') {

            steps {

                sh """

aws ecr get-login-password \
--region ${AWS_REGION} | \
docker login \
--username AWS \
--password-stdin \
${AWS_ACCOUNT}.dkr.ecr.${AWS_REGION}.amazonaws.com

"""

            }

        }

        stage('Push Docker Image') {

            steps {

                sh """

docker push \
${AWS_ACCOUNT}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPOSITORY}:${IMAGE_TAG}

"""

            }

        }

        stage('Archive Reports') {

            steps {

                archiveArtifacts artifacts: 'sbom.json', fingerprint: true

            }

        }

    }

    post {

        success {

            emailext(

                subject: "CI Pipeline SUCCESS : ${JOB_NAME} #${BUILD_NUMBER}",

                body: """

CI Pipeline Completed Successfully.

Application : ${APP_NAME}

Image Tag :

${IMAGE_TAG}

Build URL :

${BUILD_URL}

""",

                to: "devops@company.com"

            )

        }

        failure {

            emailext(

                subject: "CI Pipeline FAILED : ${JOB_NAME} #${BUILD_NUMBER}",

                body: """

CI Pipeline Failed.

Check Jenkins Console.

${BUILD_URL}

""",

                to: "devops@company.com"

            )

        }

        always {

            archiveArtifacts allowEmptyArchive: true,

            artifacts: '**/target/*.jar'

            cleanWs()

        }

    }

}
